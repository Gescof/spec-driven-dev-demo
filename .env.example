# PostgreSQL database name
POSTGRES_DB=petshop

# PostgreSQL username
POSTGRES_USER=petshop

# PostgreSQL password — change this for any shared or remote environment
POSTGRES_PASSWORD=petshop_secret

# Host port mapped to the Spring Boot backend (http://localhost:$BACKEND_PORT)
BACKEND_PORT=8080

# Host port mapped to the Nginx frontend (http://localhost:$FRONTEND_PORT)
FRONTEND_PORT=80
